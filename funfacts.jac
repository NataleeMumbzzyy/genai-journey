with entry {
  let facts = [
    "Cats sleep for around 70% of their lives",
    "Bananas are technically berries",
    "Sharks existed before trees",
    "Honey can last thousands of years",
    "Octopuses have three hearts"
  ];

  print("Here are some fun facts:");
  for f in facts {
    print("- " + f);
  }
}
